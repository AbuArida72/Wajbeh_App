{
  "expo": {
    "name": "Zaytoon",
    "slug": "wajbeh",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2E7D32"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zaytoon.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Zaytoon uses your location to show nearby restaurants and help restaurants set their location on the map.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Zaytoon uses your location to show nearby restaurants."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#2E7D32"
      },
      "package": "com.zaytoon.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyByEtWpSpvEtgLCuwoWUyt9Z6S2-r1dcYU"
        }
      }
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "extra": {
      "eas": {
        "projectId": "2ee35bf3-5c24-4a18-8b42-b872b3a7c271"
      }
    },
    "plugins": [
      "expo-font"
    ]
  }
}
